PORT=8080
NODE_ENV=production
DEMO_PUNTROSALES_FIREBASE_URL=https://firebasestorage.googleapis.com/v0/b/YOUR_BUCKET/o/catalogs%2Fdemo-puntrosales-001%2Frest.json?alt=media&token=YOUR_TOKEN

# Firestore catalog registry.
FIRESTORE_CATALOG_COLLECTION=catalog_public_routes
FIRESTORE_DATABASE_ID=(default)
CATALOG_METADATA_TTL_SECONDS=60

# Firebase Admin credentials. Use either FIREBASE_SERVICE_ACCOUNT_JSON,
# or FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY,
# or GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional endpoint for Android/backend to clear cache after changes.
INTERNAL_API_TOKEN=change-this-private-token
